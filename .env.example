# ── Auth ───────────────────────────────────────────────────────────────────────
# Set this in Arize as: Authorization: Bearer <token>
# Any random string works — generate one with: openssl rand -hex 32
EVAL_AUTH_TOKEN=your-secret-token-here

# ── LLM (only needed for llm mode) ────────────────────────────────────────────
# Provide at least one. The LLM judge uses a Star Wars canon prompt.
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Which provider to use in llm mode (default: openai)
# Accepted: openai | anthropic
LLM_PROVIDER=openai

# Model override — defaults: gpt-4o-mini (openai), claude-3-haiku-20240307 (anthropic)
LLM_MODEL=gpt-4o-mini

# ── Criteria (for llm mode) ────────────────────────────────────────────────────
# Default criteria when not specified via ?criteria= or x-eval-criteria header.
# Accepted: lore_accuracy | hallucination | relevance | in_character
# DEFAULT_CRITERIA_ID is set in code — no env var needed; override via query/header.

# ── Upstash KV (optional, for durable /requests capture) ──────────────────────
# Without these, /requests uses an in-memory ring buffer (resets on cold starts).
# Get these from https://console.upstash.com
KV_REST_API_URL=https://your-db.upstash.io
KV_REST_API_TOKEN=your-upstash-token
