# Required for auth protection on /evaluate and /tool/score
# Set this in Arize as an Authorization: Bearer <token> header
EVAL_AUTH_TOKEN=your-secret-token-here

# Required for llm mode - provide at least one
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Optional: which LLM provider to use in llm mode (default: openai)
# Accepted: openai | anthropic
LLM_PROVIDER=openai

# Optional: model name override
# Defaults: gpt-4o-mini (openai), claude-3-haiku-20240307 (anthropic)
LLM_MODEL=gpt-4o-mini

# Optional: Upstash Redis for durable /requests capture across instances
# Without these, /requests uses an in-memory ring buffer (best-effort per warm instance)
# Get these from https://console.upstash.com
KV_REST_API_URL=https://your-db.upstash.io
KV_REST_API_TOKEN=your-upstash-token
